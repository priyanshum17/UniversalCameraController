#:kivy 2.3.0

<CameraAppRoot>:
    orientation: 'vertical'
    padding: 10
    spacing: 10

    Image:
        id: main_feed
        size_hint_y: 0.8
        allow_stretch: True
        keep_ratio: True

    BoxLayout:
        size_hint_y: 0.2
        spacing: 10

        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.6
            Label:
                text: "Select Camera"
                size_hint_y: 0.3
            BoxLayout:
                size_hint_y: 0.7
                padding: [10, 5, 10, 5]
                Button:
                    id: camera_select_btn
                    text: 'Select Camera'
                    background_color: 0.2, 0.4, 0.6, 1
                    on_press: root.open_camera_selection_popup()

        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.4
            Label:
                text: "Controls"
                size_hint_y: 0.3
            BoxLayout:
                size_hint_y: 0.7
                spacing: 5
                Button:
                    text: 'Record'
                    background_color: 0, 0.8, 0, 1
                    on_press: root.start_recording()
                Button:
                    text: 'Stop'
                    background_color: 0.8, 0, 0, 1
                    on_press: root.stop_recording()
                Button:
                    text: 'Detect'
                    background_color: 0.2, 0.6, 0.8, 1
                    on_press: root.show_detected_cameras()
